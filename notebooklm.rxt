-- ============================================================
-- ПРОВЕРКА ЦЕЛОСТНОСТИ ДАННЫХ (CHECK QUERIES)
-- Запустите эти запросы, чтобы убедиться, что генератор не упадет.
-- ============================================================

-- 1. Проверка: Есть ли записи в сетке часов без назначения преподавателя?
-- (Если вернет строки, генератор пропустит эти занятия)
SELECT 
    g.name as group_name, 
    s.name as subject_name 
FROM hour_grids hg
JOIN groups g ON hg.group_id = g.id
JOIN subjects s ON hg.subject_id = s.id
LEFT JOIN teacher_subjects ts ON 
    ts.group_id = hg.group_id AND 
    ts.subject_id = hg.subject_id
WHERE ts.id IS NULL;

-- 2. Проверка: Есть ли группы без кураторов?
SELECT name FROM groups WHERE curator_id IS NULL;

-- 3. Проверка: Сумма часов в неделю (примерная)
-- Должно быть около 30-36 часов (1080-1296 за семестр)
SELECT 
    g.name, 
    SUM(hg.total_hours) as total_semester_hours
FROM hour_grids hg
JOIN groups g ON hg.group_id = g.id
WHERE hg.semester_id = 1
GROUP BY g.name;

✅ Финальный отчет
Все 5 шагов выполнены.
1. Базовые таблицы: Созданы и заполнены classrooms, teachers, groups, subjects.
2. Сетка часов 1 курса: Загружены данные для WEB, РПО, БУХ, ОП, ТК, ТП (1 курс).
3. Сетка часов 2 курса: Загружены спецдисциплины и общие предметы.
4. Сетка часов 3-4 курсов: Загружены данные выпускных групп.
5. Закрепление: Аудитории привязаны к преподавателям согласно приказу.
Теперь база данных полностью готова к запуску скрипта scheduler.py (ScheduleGenerator).