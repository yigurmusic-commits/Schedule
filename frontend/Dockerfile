# Build stage
FROM node:22-alpine AS build-stage

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

# Если передан VITE_API_URL (например, https://schedulesys-backend.onrender.com/api),
# он будет встроен в JS-бандл. Иначе фронтенд использует /api (относительный путь).
ARG VITE_API_URL=https://schedulesys-backend.onrender.com/api
ENV VITE_API_URL=$VITE_API_URL

RUN npm run build

# Production stage
FROM nginx:stable-alpine AS production-stage

COPY --from=build-stage /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
